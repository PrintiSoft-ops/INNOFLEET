{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "dest": "https://votre-backend.railway.app/api/$1"
    },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}